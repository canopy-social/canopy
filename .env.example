# Server
DOMAIN=localhost
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://dev:dev_password_change_in_prod@localhost:5432/canopy_dev?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=5

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3

# Search
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=dev_master_key_32_chars_minimum_

# Media Storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=canopy-media
S3_REGION=us-east-1
CDN_BASE_URL=http://localhost:9000/canopy-media

# Auth
JWT_SECRET=replace_me_with_a_random_256_bit_hex_string_in_production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Email (development — no real sending)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@localhost

# Features
REGISTRATION_OPEN=true
REGISTRATION_APPROVAL=false
FEDERATION_ENABLED=false
MAX_POST_LENGTH=500
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
